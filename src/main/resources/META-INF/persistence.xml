<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="hospitalPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.hospital.app.entity.Khoa</class>
        <class>com.hospital.app.entity.BacSi</class>
        <class>com.hospital.app.entity.YTa</class>
        <class>com.hospital.app.entity.CaTruc</class>
        <class>com.hospital.app.entity.BacSiCaTruc</class>
        <class>com.hospital.app.entity.YTaCaTruc</class>
        <class>com.hospital.app.entity.PhongBenh</class>
        <class>com.hospital.app.entity.BenhNhan</class>
        <class>com.hospital.app.entity.BaoHiem</class>
        <class>com.hospital.app.entity.LuotDieuTri</class>
        <class>com.hospital.app.entity.DichVu</class>
        <class>com.hospital.app.entity.ChiTietDichVu</class>
        <class>com.hospital.app.entity.DonThuoc</class>
        <class>com.hospital.app.entity.Thuoc</class>
        <class>com.hospital.app.entity.ChiTietDonThuoc</class>
        <class>com.hospital.app.entity.HoaDon</class>

        <properties>
            <!-- Cập nhật user/password theo MySQL local -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="jakarta.persistence.jdbc.user" value="${DB_USER}"/>
            <property name="jakarta.persistence.jdbc.password" value="${DB_PASSWORD}"/>
            <property name="jakarta.persistence.jdbc.url" value="${DB_URL}"/>

            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
